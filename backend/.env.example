# FrontierCRM Backend
# Copy to .env and fill in your values

# ── Django Core ──────────────────────────────────────────────────
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.production

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:***@localhost:5432/frontiercrm

# ── Redis / Celery ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1
CHANNEL_REDIS_URL=redis://localhost:6379/2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://app.frontiercrm.com

# ── Gmail / Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.frontiercrm.com/api/auth/google/callback/

# ── Meilisearch ───────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=masterKey
MEILISEARCH_INDEX_PREFIX=frontiercrm_

# ── File Storage (S3/R2) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=frontiercrm-uploads
AWS_S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto

# ── Email ─────────────────────────────────────────────────────────
DEFAULT_FROM_EMAIL=noreply@frontiercrm.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Sentry ────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Rate Limiting ─────────────────────────────────────────────────
THROTTLE_RATE_ANON=100/hour
THROTTLE_RATE_USER=1000/hour

# ── Slack Alerts ──────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_ALERT_CHANNEL=#ops-alerts

# ── Healthchecks.io (uptime monitoring) ───────────────────────────
HEALTHCHECKS_IO_URL=

# ── Backup ────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_PREFIX=backups/database